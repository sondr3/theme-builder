{
  "name": "theme-builder",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "package": "svelte-kit package",
    "preview": "vite preview",
    "prepare": "husky install",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint --cache --ignore-path=.gitignore src",
    "lint:fix": "eslint --cache --ignore-path=.gitignore --fix src",
    "format": "prettier --check --ignore-path=.gitignore --plugin-search-dir=. .",
    "format:fix": "prettier --write --ignore-path=.gitignore --plugin-search-dir=. ."
  },
  "dependencies": {
    "a11y-color-contrast": "0.2.0"
  },
  "devDependencies": {
    "@sondr3/eslint-config": "0.7.1",
    "@sondr3/prettier": "0.6.0",
    "@sondr3/tsconfig": "0.9.0",
    "@sveltejs/adapter-auto": "2.1.0",
    "@sveltejs/kit": "1.20.5",
    "@tailwindcss/forms": "0.5.3",
    "@typescript-eslint/eslint-plugin": "5.60.0",
    "@typescript-eslint/parser": "5.60.0",
    "autoprefixer": "10.4.14",
    "eslint": "8.43.0",
    "eslint-config-prettier": "8.8.0",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "4.2.1",
    "eslint-plugin-simple-import-sort": "10.0.0",
    "eslint-plugin-svelte3": "4.0.0",
    "eslint-plugin-tsdoc": "0.2.17",
    "husky": "8.0.3",
    "lint-staged": "13.2.2",
    "postcss": "8.4.24",
    "prettier": "2.8.8",
    "prettier-eslint": "15.0.1",
    "prettier-plugin-svelte": "2.10.1",
    "svelte": "4.0.0",
    "svelte-check": "3.4.4",
    "tailwindcss": "3.3.2",
    "tslib": "2.5.3",
    "typescript": "5.1.3",
    "vite": "4.3.9"
  },
  "prettier": "@sondr3/prettier",
  "lint-staged": {
    "*.{md,ts,html,js,svelte}": "prettier --write --plugin-search-dir=.",
    "*.{ts,js,svelte}": "eslint --cache --fix"
  }
}
